<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Apfelmus.Avalonia.Converters"
             x:Class="Apfelmus.Avalonia.App"
             RequestedThemeVariant="Dark">

    <Application.Resources>
        <ResourceDictionary>
            <!-- Theme-abhaengige Farben: bei RequestedThemeVariant-Wechsel greifen die passenden
                 Brushes (nur via {DynamicResource} referenziert, damit sie live umschalten). -->
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#1E2226" />
                    <SolidColorBrush x:Key="SurfaceBrush" Color="#272C31" />
                    <SolidColorBrush x:Key="AccentBrush" Color="#4CAF7D" />
                    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#ECEFF1" />
                    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#8FA0AB" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#F4F6F8" />
                    <SolidColorBrush x:Key="SurfaceBrush" Color="#E3E7EB" />
                    <SolidColorBrush x:Key="AccentBrush" Color="#2E8B57" />
                    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1E2226" />
                    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#556069" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <!-- Avalonia-Converter (Portierungen der WPF-IValueConverter). -->
            <conv:FirewallConverter x:Key="FirewallConverter" />
            <conv:FileSizeConverter x:Key="FileSizeConverter" />
            <conv:BoolToFirewallTextConverter x:Key="BoolToFirewallTextConverter" />
            <conv:DownloadStatusConverter x:Key="DownloadStatusConverter" />
            <conv:TimeConverter x:Key="TimeConverter" />
            <conv:SecondsToDateConverter x:Key="SecondsToDateConverter" />
            <conv:PowerDownloadConverter x:Key="PowerDownloadConverter" />
            <conv:UserStatusConverter x:Key="UserStatusConverter" />
            <conv:DownloadRowBrushConverter x:Key="DownloadRowBrushConverter" />
            <conv:ServerRowBrushConverter x:Key="ServerRowBrushConverter" />
            <conv:ExtensionToIconConverter x:Key="FileIconConverter" />
            <conv:PercentTextConverter x:Key="PercentTextConverter" />
            <conv:NetworkSizeConverter x:Key="NetworkSizeConverter" />
            <conv:ConnectedDotConverter x:Key="ConnectedDotConverter" />
            <conv:BoolToFontWeightConverter x:Key="BoolToFontWeightConverter" />

            <!-- Ordner-Icon (Mein Share: Baum + freigegebene Ordner); gruene Variante = freigegeben -->
            <DrawingImage x:Key="FolderIcon">
                <GeometryDrawing Brush="#E0B24C" Geometry="M2,5 H8 L10,7 H21 V19 H2 Z" />
            </DrawingImage>
            <DrawingImage x:Key="FolderIconShared">
                <GeometryDrawing Brush="#4CAF7D" Geometry="M2,5 H8 L10,7 H21 V19 H2 Z" />
            </DrawingImage>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml" />

        <!-- Kartenlayout fuer den Start-Tab (Ersatz fuer WPF-GroupBox) -->
        <Style Selector="Border.card">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Margin" Value="10" />
        </Style>
        <Style Selector="TextBlock.cardheader">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>
        <Style Selector="TextBlock.lbl">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        </Style>
        <Style Selector="TextBlock.val">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>

        <!-- Fensterkontroll-Buttons der eigenen Titelleiste -->
        <Style Selector="Button.titlebtn">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.titlebtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#33FFFFFF" />
        </Style>
        <Style Selector="Button.titleclose:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#E81123" />
            <Setter Property="Foreground" Value="White" />
        </Style>
    </Application.Styles>
</Application>
