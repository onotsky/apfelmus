<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Apfelmus.Avalonia.Views.TargetDirDialog"
        Title="{DynamicResource d_targetdir}" Width="460" Height="460"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}">
    <DockPanel Margin="16">
        <TextBlock DockPanel.Dock="Top" Text="{DynamicResource td_pick}" Margin="0,0,0,8"
                   Foreground="{DynamicResource TextSecondaryBrush}" />

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="OK" Click="Ok_Click" Background="{DynamicResource AccentBrush}" Foreground="White" />
            <Button Content="{DynamicResource d_cancel}" Click="Cancel_Click" />
        </StackPanel>

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="6" Margin="0,10,0,0">
            <TextBlock Text="{DynamicResource td_newfolder}" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextSecondaryBrush}" />
            <TextBox x:Name="NewFolderBox" Width="240" Watermark="(optional)" />
        </StackPanel>

        <Border BorderBrush="{DynamicResource SurfaceBrush}" BorderThickness="1" CornerRadius="4">
            <TreeView x:Name="DirTreeView" x:CompileBindings="False">
                <TreeView.Styles>
                    <Style Selector="TreeViewItem">
                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                    </Style>
                </TreeView.Styles>
                <TreeView.ItemTemplate>
                    <TreeDataTemplate ItemsSource="{Binding Children}">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <Image Source="{StaticResource FolderIcon}" Width="15" Height="15" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}" />
                        </StackPanel>
                    </TreeDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </Border>
    </DockPanel>
</Window>
