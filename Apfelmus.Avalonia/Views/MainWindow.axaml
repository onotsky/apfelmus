<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Apfelmus.Avalonia.ViewModels"
        xmlns:m="clr-namespace:ApfelmusFramework.Classes.Modified;assembly=ApfelmusFramework"
        x:Class="Apfelmus.Avalonia.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Apfelmus" Width="1000" Height="680"
        WindowStartupLocation="CenterScreen"
        Icon="avares://Apfelmus.Avalonia/Assets/Images/Apple-icon.png"
        Background="{StaticResource WindowBackgroundBrush}"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="-1">

    <DockPanel>
        <!-- ===== Eigene Titelleiste (rahmenloses Fenster, folgt dem App-Theme) ===== -->
        <Grid DockPanel.Dock="Top" Height="34" Background="{StaticResource SurfaceBrush}"
              PointerPressed="TitleBar_PointerPressed" DoubleTapped="TitleBar_DoubleTapped">
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="10,0" VerticalAlignment="Center" HorizontalAlignment="Left">
                <Image Source="avares://Apfelmus.Avalonia/Assets/Images/Apple-icon.png" Width="16" Height="16" />
                <TextBlock Text="Apfelmus" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="0">
                <Button Classes="titlebtn" Click="Minimize_Click">—</Button>
                <Button Classes="titlebtn" Click="MaxRestore_Click">▢</Button>
                <Button Classes="titlebtn titleclose" Click="Close_Click">✕</Button>
            </StackPanel>
        </Grid>

        <!-- ===== Menueleiste ===== -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="{DynamicResource m_design}">
                <MenuItem Header="{DynamicResource m_dark}" Command="{Binding ApplyDarkThemeCommand}" />
                <MenuItem Header="{DynamicResource m_light}" Command="{Binding ApplyLightThemeCommand}" />
            </MenuItem>
            <MenuItem Header="{DynamicResource m_language}">
                <MenuItem Header="{DynamicResource m_german}" Command="{Binding GermanCommand}" />
                <MenuItem Header="{DynamicResource m_english}" Command="{Binding EnglishCommand}" />
                <MenuItem Header="{DynamicResource m_italian}" Command="{Binding ItalianCommand}" />
            </MenuItem>
            <MenuItem Header="{DynamicResource m_core}">
                <MenuItem Header="{DynamicResource m_coreexit}" Command="{Binding CoreExitCommand}" />
            </MenuItem>
        </Menu>

        <!-- ===== AJLink-Transfer ===== -->
        <Border DockPanel.Dock="Top" Background="{StaticResource SurfaceBrush}" Padding="8,6">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Image Source="avares://Apfelmus.Avalonia/Assets/Images/Apple-icon.png" Width="18" Height="18" VerticalAlignment="Center" />
                <TextBlock Text="{DynamicResource ajlink}" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" />
                <TextBox Width="640" Watermark="ajfsp://file|..." Text="{Binding AjLinkText, Mode=TwoWay}" />
                <Button Content="{DynamicResource transfer}" Command="{Binding TransferAjLinkCommand}" />
                <TextBlock Text="{Binding ConnectionStatus}" VerticalAlignment="Center" Margin="12,0,0,0" Foreground="{StaticResource AccentBrush}" />
            </StackPanel>
        </Border>

        <!-- ===== Statusleiste (unten) ===== -->
        <Border DockPanel.Dock="Bottom" Background="{StaticResource SurfaceBrush}" Padding="8,4">
            <StackPanel Orientation="Horizontal" Spacing="18">
                <TextBlock Foreground="{StaticResource TextSecondaryBrush}">
                    <Run Text="Credits: " /><Run Text="{Binding Credits, Converter={StaticResource FileSizeConverter}}" />
                </TextBlock>
                <TextBlock Foreground="{StaticResource TextSecondaryBrush}">
                    <Run Text="Upload: " /><Run Text="{Binding UploadSpeed, Converter={StaticResource FileSizeConverter}}" /><Run Text="/s" />
                </TextBlock>
                <TextBlock Foreground="{StaticResource TextSecondaryBrush}">
                    <Run Text="Download: " /><Run Text="{Binding DownloadSpeed, Converter={StaticResource FileSizeConverter}}" /><Run Text="/s" />
                </TextBlock>
                <TextBlock Foreground="{StaticResource TextSecondaryBrush}">
                    <Run Text="Traffic: " /><Run Text="{Binding SessionDownload, Converter={StaticResource FileSizeConverter}}" /><Run Text=" in / " /><Run Text="{Binding SessionUpload, Converter={StaticResource FileSizeConverter}}" /><Run Text=" out" />
                </TextBlock>
            </StackPanel>
        </Border>

        <TabControl Margin="6">
            <!-- ===================== START ===================== -->
            <TabItem Header="{DynamicResource t_start}">
                <ScrollViewer>
                    <WrapPanel Margin="12">
                        <Border Classes="card" Width="280" Height="110">
                            <StackPanel Spacing="4">
                                <TextBlock Text="{DynamicResource c_client}" Classes="cardheader" />
                                <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource c_gui}" Classes="lbl" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding GuiVersion}" Classes="val" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource c_core}" Classes="lbl" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CoreVersion}" Classes="val" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Classes="card" Width="300" Height="230">
                            <StackPanel Spacing="4">
                                <TextBlock Text="{DynamicResource c_network}" Classes="cardheader" />
                                <Grid ColumnDefinitions="150,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource c_users}" Classes="lbl" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Users}" Classes="val" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource c_files}" Classes="lbl" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Files}" Classes="val" />
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource c_totalsize}" Classes="lbl" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding FileSize, Converter={StaticResource FileSizeConverter}}" Classes="val" />
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="{DynamicResource c_connections}" Classes="lbl" />
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding OpenConnections}" Classes="val" />
                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="{DynamicResource c_uploadqueue}" Classes="lbl" />
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding UploadQueue}" Classes="val" />
                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="{DynamicResource c_firewall}" Classes="lbl" />
                                    <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal" Spacing="6">
                                        <Image Width="14" Height="14" Source="{Binding Firewalled, Converter={StaticResource FirewallConverter}}" />
                                        <TextBlock Classes="val" Text="{Binding Firewalled, Converter={StaticResource BoolToFirewallTextConverter}}" />
                                    </StackPanel>
                                    <TextBlock Grid.Row="6" Grid.Column="0" Text="{DynamicResource c_ip}" Classes="lbl" />
                                    <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding OwnIp}" Classes="val" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Classes="card" Width="420" Height="230">
                            <StackPanel Spacing="4">
                                <TextBlock Text="{DynamicResource c_server}" Classes="cardheader" />
                                <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource c_servername}" Classes="lbl" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ServerName}" Classes="val" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource c_connectedsince}" Classes="lbl" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ConnectedSince}" Classes="val" />
                                </Grid>
                                <TextBlock Text="{DynamicResource c_message}" Classes="lbl" Margin="0,6,0,0" />
                                <ScrollViewer Height="120">
                                    <TextBlock Text="{Binding WelcomeMessage}" Classes="val" TextWrapping="Wrap" />
                                </ScrollViewer>
                            </StackPanel>
                        </Border>
                    </WrapPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ===================== DOWNLOADS ===================== -->
            <TabItem Header="{DynamicResource t_downloads}">
                <DockPanel Margin="4">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="6" Margin="4">
                        <Button Content="{DynamicResource d_continue}" Command="{Binding ContinueCommand}" />
                        <Button Content="{DynamicResource d_break}" Command="{Binding BreakCommand}" />
                        <Button Content="{DynamicResource d_cancel}" Command="{Binding CancelCommand}" />
                        <Button Content="{DynamicResource d_clean}" Command="{Binding CleanFinishedCommand}" />
                        <Button Content="{DynamicResource d_releaseinfo}" Command="{Binding ReleaseInfoDownloadCommand}" />
                        <Button Content="{DynamicResource d_copylink}" Command="{Binding CopyDownloadLinkCommand}" />
                        <Border Width="1" Background="{StaticResource TextSecondaryBrush}" Margin="4,0" />
                        <TextBlock Text="{DynamicResource d_power}" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" />
                        <ComboBox x:CompileBindings="False" Width="70" ItemsSource="{Binding PowerValues}" SelectedItem="{Binding SelectedPowerValue}" />
                        <Button Content="{DynamicResource d_apply}" Command="{Binding ApplyPowerDownloadCommand}" />
                        <TextBlock Text="{DynamicResource d_priority}" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" />
                        <ComboBox x:CompileBindings="False" Width="70" ItemsSource="{Binding PriorityValues}" SelectedItem="{Binding SelectedPriority}" />
                        <Button Content="{DynamicResource d_setprio}" Command="{Binding SetDownloadPriorityCommand}" />
                    </StackPanel>

                    <Grid RowDefinitions="*,4,160,74">
                        <DataGrid Grid.Row="0" x:CompileBindings="False" ItemsSource="{Binding Downloads}"
                                  SelectedItem="{Binding SelectedDownload}" IsReadOnly="True"
                                  GridLinesVisibility="Horizontal" CanUserResizeColumns="True">
                            <DataGrid.Styles>
                                <Style Selector="DataGridRow">
                                    <Setter Property="Background" Value="{Binding Status, Converter={StaticResource DownloadRowBrushConverter}}" />
                                </Style>
                            </DataGrid.Styles>
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="{DynamicResource col_file}" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                                                <Image Width="16" Height="16" Source="{Binding FileName, Converter={StaticResource FileIconConverter}}" />
                                                <TextBlock Text="{Binding FileName}" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="{DynamicResource col_status}" Binding="{Binding Status, Converter={StaticResource DownloadStatusConverter}}" Width="110" />
                                <DataGridTextColumn Header="{DynamicResource col_size}" Binding="{Binding Size, Converter={StaticResource FileSizeConverter}}" Width="90" />
                                <DataGridTextColumn Header="{DynamicResource col_loaded}" Binding="{Binding DownloadedFilesize, Converter={StaticResource FileSizeConverter}}" Width="90" />
                                <DataGridTextColumn Header="{DynamicResource col_speed}" Binding="{Binding Speed, Converter={StaticResource FileSizeConverter}}" Width="90" />
                                <DataGridTextColumn Header="{DynamicResource col_time}" Binding="{Binding TimeToEnd, Converter={StaticResource TimeConverter}}" Width="90" />
                                <DataGridTextColumn Header="{DynamicResource col_percent}" Binding="{Binding Percentages}" Width="60" />
                                <DataGridTextColumn Header="{DynamicResource col_rest}" Binding="{Binding DownloadRest, Converter={StaticResource FileSizeConverter}}" Width="90" />
                                <DataGridTextColumn Header="{DynamicResource col_power}" Binding="{Binding PowerDownload, Converter={StaticResource PowerDownloadConverter}}" Width="70" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <GridSplitter Grid.Row="1" ResizeDirection="Rows" HorizontalAlignment="Stretch" Background="{StaticResource SurfaceBrush}" />

                        <DockPanel Grid.Row="2">
                            <TextBlock DockPanel.Dock="Top" Text="{DynamicResource d_sources}" Classes="lbl" Margin="2" />
                            <DataGrid x:CompileBindings="False" ItemsSource="{Binding DownloadSources}" IsReadOnly="True"
                                      GridLinesVisibility="Horizontal" CanUserResizeColumns="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="{DynamicResource col_nick}" Binding="{Binding NickName}" Width="*" />
                                    <DataGridTextColumn Header="{DynamicResource col_status}" Binding="{Binding Status, Converter={StaticResource UserStatusConverter}}" Width="120" />
                                    <DataGridTextColumn Header="{DynamicResource col_speed}" Binding="{Binding Speed, Converter={StaticResource FileSizeConverter}}" Width="90" />
                                    <DataGridTextColumn Header="{DynamicResource col_version}" Binding="{Binding Version}" Width="120" />
                                    <DataGridTextColumn Header="{DynamicResource col_power}" Binding="{Binding PowerDownload, Converter={StaticResource PowerDownloadConverter}}" Width="70" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>

                        <!-- Partlisten-Verfuegbarkeitsbalken des gewaehlten Downloads -->
                        <DockPanel Grid.Row="3" Margin="2,4,2,2">
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="12" Margin="0,0,0,3">
                                <TextBlock Text="{DynamicResource pl_title}" Classes="lbl" VerticalAlignment="Center" />
                                <StackPanel Orientation="Horizontal" Spacing="3" VerticalAlignment="Center">
                                    <Rectangle Width="10" Height="10" Fill="Red" /><TextBlock Text="{DynamicResource pl_unavail}" Classes="lbl" />
                                    <Rectangle Width="10" Height="10" Fill="#4C6BFF" Margin="8,0,0,0" /><TextBlock Text="{DynamicResource pl_avail}" Classes="lbl" />
                                    <Rectangle Width="10" Height="10" Fill="Orange" Margin="8,0,0,0" /><TextBlock Text="{DynamicResource pl_loaded}" Classes="lbl" />
                                    <Rectangle Width="10" Height="10" Fill="Yellow" Margin="8,0,0,0" /><TextBlock Text="{DynamicResource pl_active}" Classes="lbl" />
                                    <Rectangle Width="10" Height="10" Fill="Green" Margin="8,0,0,0" /><TextBlock Text="{DynamicResource pl_finished}" Classes="lbl" />
                                </StackPanel>
                            </StackPanel>
                            <Border BorderBrush="{StaticResource TextSecondaryBrush}" BorderThickness="1">
                                <Image Source="{Binding PartlistImage}" Stretch="Fill" />
                            </Border>
                        </DockPanel>
                    </Grid>
                </DockPanel>
            </TabItem>

            <!-- ===================== UPLOADS ===================== -->
            <TabItem Header="{DynamicResource t_uploads}">
                <DataGrid x:CompileBindings="False" Margin="4" ItemsSource="{Binding Uploads}" IsReadOnly="True"
                          GridLinesVisibility="Horizontal" CanUserResizeColumns="True">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="{DynamicResource col_file}" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                                                <Image Width="16" Height="16" Source="{Binding FileName, Converter={StaticResource FileIconConverter}}" />
                                                <TextBlock Text="{Binding FileName}" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                        <DataGridTextColumn Header="{DynamicResource col_nick}" Binding="{Binding Nick}" Width="140" />
                        <DataGridTextColumn Header="{DynamicResource col_speed}" Binding="{Binding Speed, Converter={StaticResource FileSizeConverter}}" Width="90" />
                        <DataGridTextColumn Header="{DynamicResource col_percent}" Binding="{Binding Percentages}" Width="70" />
                        <DataGridTextColumn Header="{DynamicResource col_prio}" Binding="{Binding Priority}" Width="80" />
                        <DataGridTextColumn Header="{DynamicResource col_version}" Binding="{Binding Version}" Width="140" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <!-- ===================== SUCHEN ===================== -->
            <TabItem Header="{DynamicResource t_search}">
                <DockPanel Margin="4">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="6" Margin="4">
                        <TextBox Width="300" Watermark="{DynamicResource s_placeholder}" Text="{Binding SearchText, Mode=TwoWay}" />
                        <Button Content="{DynamicResource s_search}" Command="{Binding StartSearchCommand}" />
                        <Button Content="{DynamicResource s_stop}" Command="{Binding StopSearchCommand}" />
                        <Button Content="{DynamicResource s_download}" Command="{Binding DownloadSearchResultCommand}" />
                        <Button Content="{DynamicResource d_releaseinfo}" Command="{Binding ReleaseInfoSearchCommand}" />
                        <Button Content="{DynamicResource d_copylink}" Command="{Binding CopySearchLinkCommand}" />
                        <TextBlock VerticalAlignment="Center" Margin="10,0,0,0" Foreground="{StaticResource TextSecondaryBrush}">
                            <Run Text="Treffer: " /><Run Text="{Binding FoundFiles}" /><Run Text="  Quellen: " /><Run Text="{Binding SumSearches}" />
                        </TextBlock>
                    </StackPanel>
                    <DataGrid x:CompileBindings="False" ItemsSource="{Binding SearchResults}"
                              SelectedItem="{Binding SelectedSearchResult}" IsReadOnly="True"
                              GridLinesVisibility="Horizontal" CanUserResizeColumns="True">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="{DynamicResource col_file}" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                                                <Image Width="16" Height="16" Source="{Binding FileName.Name, Converter={StaticResource FileIconConverter}}" />
                                                <TextBlock Text="{Binding FileName.Name}" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            <DataGridTextColumn Header="{DynamicResource col_size}" Binding="{Binding Size, Converter={StaticResource FileSizeConverter}}" Width="100" />
                            <DataGridTextColumn Header="{DynamicResource col_checksum}" Binding="{Binding Checksum}" Width="260" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <!-- ===================== SERVER ===================== -->
            <TabItem Header="{DynamicResource t_server}">
                <DockPanel Margin="4">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="6" Margin="4">
                        <Button Content="{DynamicResource sv_connect}" Command="{Binding ConnectServerCommand}" />
                        <Button Content="{DynamicResource sv_remove}" Command="{Binding RemoveServerCommand}" />
                        <Button Content="{DynamicResource sv_getlist}" Command="{Binding AddOfficialServersCommand}" />
                    </StackPanel>
                    <DataGrid x:CompileBindings="False" ItemsSource="{Binding Servers}"
                              SelectedItem="{Binding SelectedServer}" IsReadOnly="True"
                              GridLinesVisibility="Horizontal" CanUserResizeColumns="True">
                        <DataGrid.Styles>
                            <Style Selector="DataGridRow">
                                <Setter Property="Background" Value="{Binding IsConnected, Converter={StaticResource ServerRowBrushConverter}}" />
                            </Style>
                        </DataGrid.Styles>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{DynamicResource col_name}" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="{DynamicResource col_host}" Binding="{Binding Host}" Width="220" />
                            <DataGridTextColumn Header="{DynamicResource col_port}" Binding="{Binding Port}" Width="80" />
                            <DataGridTextColumn Header="{DynamicResource col_lastseen}" Binding="{Binding LastSeen, Converter={StaticResource SecondsToDateConverter}}" Width="150" />
                            <DataGridTextColumn Header="{DynamicResource col_tries}" Binding="{Binding ConnectionTry}" Width="90" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <!-- ===================== MEIN SHARE ===================== -->
            <TabItem Header="{DynamicResource t_share}">
                <Grid ColumnDefinitions="320,4,*" Margin="4">
                    <!-- Links: Freigabe-Verzeichnisbaum -->
                    <DockPanel Grid.Column="0">
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="6" Margin="2">
                            <Button Content="{DynamicResource sh_loadtree}" Command="{Binding LoadShareTreeCommand}" />
                            <Button Content="{DynamicResource sh_unshare}" Command="{Binding UnshareFolderCommand}" />
                        </StackPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="6" Margin="2,0,2,2">
                            <Button Content="{DynamicResource sh_share}" Command="{Binding ShareFolderNoSubCommand}" />
                            <Button Content="{DynamicResource sh_sharesub}" Command="{Binding ShareFolderCommand}" />
                        </StackPanel>
                        <TextBlock DockPanel.Dock="Top" Text="{DynamicResource sh_dirs}" Classes="lbl" Margin="2,0,0,2" />
                        <TreeView x:CompileBindings="False" ItemsSource="{Binding ShareTree}" SelectedItem="{Binding SelectedShareNode}">
                            <TreeView.Styles>
                                <Style Selector="TreeViewItem">
                                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                </Style>
                            </TreeView.Styles>
                            <TreeView.ItemTemplate>
                                <TreeDataTemplate ItemsSource="{Binding Children}">
                                    <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextPrimaryBrush}" />
                                </TreeDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </DockPanel>

                    <GridSplitter Grid.Column="1" ResizeDirection="Columns" Background="{StaticResource SurfaceBrush}" />

                    <!-- Rechts: freigegebene Dateien -->
                    <DockPanel Grid.Column="2">
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="6" Margin="4">
                            <TextBlock Text="{DynamicResource d_priority}" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" />
                            <ComboBox x:CompileBindings="False" Width="70" ItemsSource="{Binding PriorityValues}" SelectedItem="{Binding SelectedPriority}" />
                            <Button Content="{DynamicResource sh_setprio}" Command="{Binding SetSharePriorityCommand}" />
                            <Button Content="{DynamicResource sh_delprio}" Command="{Binding DelSharePriorityCommand}" />
                            <Button Content="{DynamicResource d_copylink}" Command="{Binding CopyShareLinkCommand}" />
                            <Button Content="{DynamicResource d_releaseinfo}" Command="{Binding ReleaseInfoShareCommand}" />
                        </StackPanel>
                        <DataGrid x:CompileBindings="False" ItemsSource="{Binding Shares}"
                                  SelectedItem="{Binding SelectedShare}" IsReadOnly="True"
                                  GridLinesVisibility="Horizontal" CanUserResizeColumns="True">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="{DynamicResource col_file}" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                                                <Image Width="16" Height="16" Source="{Binding ShortFileName, Converter={StaticResource FileIconConverter}}" />
                                                <TextBlock Text="{Binding ShortFileName}" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="{DynamicResource col_size}" Binding="{Binding Size, Converter={StaticResource FileSizeConverter}}" Width="100" />
                                <DataGridTextColumn Header="{DynamicResource col_prio}" Binding="{Binding Priority}" Width="80" />
                                <DataGridTextColumn Header="{DynamicResource col_lastasked}" Binding="{Binding LastAsked, Converter={StaticResource SecondsToDateConverter}}" Width="150" />
                                <DataGridTextColumn Header="{DynamicResource col_asks}" Binding="{Binding AskCount}" Width="90" />
                                <DataGridTextColumn Header="{DynamicResource col_hits}" Binding="{Binding SearchCount}" Width="100" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Grid>
            </TabItem>

            <!-- ===================== EINSTELLUNGEN ===================== -->
            <TabItem Header="{DynamicResource t_settings}">
                <ScrollViewer>
                <StackPanel Margin="16" Spacing="12" MaxWidth="680" HorizontalAlignment="Left">
                    <TextBlock Text="{DynamicResource c_gui}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                    <Grid ColumnDefinitions="220,*" RowDefinitions="Auto,Auto,Auto">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource set_refresh}" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBox Grid.Row="0" Grid.Column="1" Width="120" HorizontalAlignment="Left" Text="{Binding RefreshRate, Mode=TwoWay}" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource set_infourl}" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,8,0,0" />
                        <TextBox Grid.Row="1" Grid.Column="1" Margin="0,8,0,0" Text="{Binding ReleaseInfoHost, Mode=TwoWay}" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource set_design}" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,8,0,0" />
                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Spacing="6" Margin="0,8,0,0">
                            <Button Content="Dunkel" Command="{Binding ApplyDarkThemeCommand}" />
                            <Button Content="Hell" Command="{Binding ApplyLightThemeCommand}" />
                        </StackPanel>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Content="{DynamicResource set_guisave}" Command="{Binding SaveSettingsCommand}" Background="{StaticResource AccentBrush}" Foreground="White" />
                        <TextBlock Text="{Binding SettingsStatus}" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>

                    <Border Height="1" Background="{StaticResource SurfaceBrush}" Margin="0,8" />

                    <TextBlock Text="{DynamicResource set_core}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                    <Grid ColumnDefinitions="220,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource set_nick}" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBox  Grid.Row="0" Grid.Column="1" Text="{Binding CoreNick, Mode=TwoWay}" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource set_tempdir}" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,0" />
                        <TextBox  Grid.Row="1" Grid.Column="1" Margin="0,6,0,0" Text="{Binding CoreTempDir, Mode=TwoWay}" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource set_incdir}" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,0" />
                        <TextBox  Grid.Row="2" Grid.Column="1" Margin="0,6,0,0" Text="{Binding CoreIncomingDir, Mode=TwoWay}" />
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="{DynamicResource set_coreport}" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,0" />
                        <TextBox  Grid.Row="3" Grid.Column="1" Width="120" HorizontalAlignment="Left" Margin="0,6,0,0" Text="{Binding CorePort, Mode=TwoWay}" />
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="{DynamicResource set_xmlport}" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,0" />
                        <TextBox  Grid.Row="4" Grid.Column="1" Width="120" HorizontalAlignment="Left" Margin="0,6,0,0" Text="{Binding CoreXmlPort, Mode=TwoWay}" />
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="{DynamicResource set_maxconn}" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,0" />
                        <TextBox  Grid.Row="5" Grid.Column="1" Width="120" HorizontalAlignment="Left" Margin="0,6,0,0" Text="{Binding CoreMaxConnections, Mode=TwoWay}" />
                        <TextBlock Grid.Row="6" Grid.Column="0" Text="{DynamicResource set_maxup}" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,0" />
                        <TextBox  Grid.Row="6" Grid.Column="1" Width="160" HorizontalAlignment="Left" Margin="0,6,0,0" Text="{Binding CoreMaxUpload, Mode=TwoWay}" />
                        <TextBlock Grid.Row="7" Grid.Column="0" Text="{DynamicResource set_maxdown}" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,0" />
                        <TextBox  Grid.Row="7" Grid.Column="1" Width="160" HorizontalAlignment="Left" Margin="0,6,0,0" Text="{Binding CoreMaxDownload, Mode=TwoWay}" />
                        <TextBlock Grid.Row="8" Grid.Column="0" Text="{DynamicResource set_speedslot}" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,0" />
                        <TextBox  Grid.Row="8" Grid.Column="1" Width="160" HorizontalAlignment="Left" Margin="0,6,0,0" Text="{Binding CoreSpeedPerSlot, Mode=TwoWay}" />
                        <TextBlock Grid.Row="9" Grid.Column="0" Text="{DynamicResource set_newconn}" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,0" />
                        <TextBox  Grid.Row="9" Grid.Column="1" Width="120" HorizontalAlignment="Left" Margin="0,6,0,0" Text="{Binding CoreMaxNewConnectionsPerTurn, Mode=TwoWay}" />
                        <TextBlock Grid.Row="10" Grid.Column="0" Text="{DynamicResource set_sources}" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,0" />
                        <TextBox  Grid.Row="10" Grid.Column="1" Width="120" HorizontalAlignment="Left" Margin="0,6,0,0" Text="{Binding CoreMaxSourcesPerFile, Mode=TwoWay}" />
                    </Grid>
                    <CheckBox Content="{DynamicResource set_autoconnect}" IsChecked="{Binding CoreAutoConnect, Mode=TwoWay}" Foreground="{StaticResource TextPrimaryBrush}" />
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Content="{DynamicResource set_coreload}" Command="{Binding LoadCoreSettingsCommand}" />
                        <Button Content="{DynamicResource set_coresave}" Command="{Binding SaveCoreSettingsCommand}" Background="{StaticResource AccentBrush}" Foreground="White" />
                        <TextBlock Text="{Binding CoreSettingsStatus}" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>

                    <Border Height="1" Background="{StaticResource SurfaceBrush}" Margin="0,8" />

                    <TextBlock Text="{DynamicResource set_pwchange}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBox Width="220" PasswordChar="•" Watermark="{DynamicResource set_newpw}" Text="{Binding NewPassword, Mode=TwoWay}" />
                        <Button Content="{DynamicResource set_pwset}" Command="{Binding ChangePasswordCommand}" />
                    </StackPanel>
                </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
