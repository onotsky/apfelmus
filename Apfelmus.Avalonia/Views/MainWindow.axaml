<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Apfelmus.Avalonia.ViewModels"
        xmlns:m="clr-namespace:ApfelmusFramework.Classes.Modified;assembly=ApfelmusFramework"
        x:Class="Apfelmus.Avalonia.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Apfelmus" Width="1000" Height="680"
        WindowStartupLocation="CenterScreen"
        Icon="avares://Apfelmus.Avalonia/Assets/Images/Apple-icon.png"
        Background="{DynamicResource WindowBackgroundBrush}"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="-1">

    <!-- Tastenkuerzel fuer die Downloadliste (wie WPF-Client) -->
    <Window.KeyBindings>
        <KeyBinding Gesture="F2" Command="{Binding ContinueCommand}" />
        <KeyBinding Gesture="F3" Command="{Binding BreakCommand}" />
        <KeyBinding Gesture="F4" Command="{Binding CancelCommand}" />
        <KeyBinding Gesture="F5" Command="{Binding CleanFinishedCommand}" />
        <KeyBinding Gesture="F6" Command="{Binding RenameCommand}" />
        <KeyBinding Gesture="F7" Command="{Binding SetTargetDirCommand}" />
        <KeyBinding Gesture="F8" Command="{Binding CopyDownloadLinkCommand}" />
        <KeyBinding Gesture="F9" Command="{Binding CopyDownloadSourceCommand}" />
    </Window.KeyBindings>

    <DockPanel>
        <!-- ===== Eigene Titelleiste (rahmenloses Fenster, folgt dem App-Theme) ===== -->
        <Grid DockPanel.Dock="Top" Height="34" Background="{DynamicResource SurfaceBrush}"
              PointerPressed="TitleBar_PointerPressed" DoubleTapped="TitleBar_DoubleTapped">
            <StackPanel x:Name="TitleLeft" Orientation="Horizontal" Spacing="8" Margin="10,0" VerticalAlignment="Center" HorizontalAlignment="Left">
                <Image Source="avares://Apfelmus.Avalonia/Assets/Images/Apple-icon.png" Width="16" Height="16" />
                <TextBlock Text="Apfelmus" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}" />
            </StackPanel>
            <!-- Eigene Fensterknoepfe (Windows/Linux). Auf macOS ausgeblendet -> native Ampeln links. -->
            <StackPanel x:Name="TitleButtons" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="0">
                <Button Classes="titlebtn" Click="Minimize_Click">—</Button>
                <Button Classes="titlebtn" Click="MaxRestore_Click">▢</Button>
                <Button Classes="titlebtn titleclose" Click="Close_Click">✕</Button>
            </StackPanel>
        </Grid>

        <!-- ===== Menueleiste ===== -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="{DynamicResource m_design}">
                <MenuItem Header="{DynamicResource m_dark}" Command="{Binding ApplyDarkThemeCommand}" />
                <MenuItem Header="{DynamicResource m_light}" Command="{Binding ApplyLightThemeCommand}" />
            </MenuItem>
            <MenuItem Header="{DynamicResource m_language}">
                <MenuItem Header="{DynamicResource m_german}" Command="{Binding GermanCommand}" />
                <MenuItem Header="{DynamicResource m_english}" Command="{Binding EnglishCommand}" />
                <MenuItem Header="{DynamicResource m_italian}" Command="{Binding ItalianCommand}" />
            </MenuItem>
            <MenuItem Header="{DynamicResource m_core}">
                <MenuItem Header="{DynamicResource m_coreexit}" Command="{Binding CoreExitCommand}" />
            </MenuItem>
            <MenuItem Header="{DynamicResource m_help}">
                <MenuItem Header="{DynamicResource m_checkupdate}" Command="{Binding CheckForUpdatesCommand}" />
            </MenuItem>
        </Menu>

        <!-- ===== AJLink-Transfer ===== -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource SurfaceBrush}" Padding="8,6">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Image Source="avares://Apfelmus.Avalonia/Assets/Images/Apple-icon.png" Width="18" Height="18" VerticalAlignment="Center" />
                <TextBlock Text="{DynamicResource ajlink}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" />
                <TextBox Width="640" Watermark="ajfsp://file|..." Text="{Binding AjLinkText, Mode=TwoWay}" />
                <Button Content="{DynamicResource transfer}" Command="{Binding TransferAjLinkCommand}" />
                <TextBlock Text="{Binding ConnectionStatus}" VerticalAlignment="Center" Margin="12,0,0,0" Foreground="{DynamicResource AccentBrush}" />
            </StackPanel>
        </Border>

        <!-- ===== Statusleiste (unten) ===== -->
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource SurfaceBrush}" Padding="8,4">
            <StackPanel Orientation="Horizontal" Spacing="18">
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <Ellipse Width="9" Height="9" VerticalAlignment="Center"
                             Fill="{Binding IsConnected, Converter={StaticResource ConnectedDotConverter}}" />
                    <TextBlock Text="{Binding ServerName}" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}" />
                </StackPanel>
                <TextBlock Foreground="{DynamicResource TextSecondaryBrush}">
                    <Run Text="Credits: " /><Run Text="{Binding Credits, Converter={StaticResource FileSizeConverter}}" />
                </TextBlock>
                <TextBlock Foreground="{DynamicResource TextSecondaryBrush}">
                    <Run Text="Upload: " /><Run Text="{Binding UploadSpeed, Converter={StaticResource FileSizeConverter}}" /><Run Text="/s" />
                </TextBlock>
                <TextBlock Foreground="{DynamicResource TextSecondaryBrush}">
                    <Run Text="Download: " /><Run Text="{Binding DownloadSpeed, Converter={StaticResource FileSizeConverter}}" /><Run Text="/s" />
                </TextBlock>
                <TextBlock Foreground="{DynamicResource TextSecondaryBrush}">
                    <Run Text="Traffic: " /><Run Text="{Binding SessionDownload, Converter={StaticResource FileSizeConverter}}" /><Run Text=" in / " /><Run Text="{Binding SessionUpload, Converter={StaticResource FileSizeConverter}}" /><Run Text=" out" />
                </TextBlock>
                <!-- Ergebnis der manuellen Update-Pruefung (z.B. "Sie haben die neueste Version.") -->
                <TextBlock Text="{Binding UpdateStatus}" IsVisible="{Binding HasUpdateStatus}"
                           VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" />
                <!-- Update-Hinweis: nur sichtbar, wenn eine neuere Version verfuegbar ist -> oeffnet die Release-Seite -->
                <Button Content="{Binding UpdateHint}" Command="{Binding OpenLatestReleaseCommand}"
                        IsVisible="{Binding UpdateAvailable}" Background="{DynamicResource AccentBrush}"
                        Foreground="White" Padding="8,2" VerticalAlignment="Center" Cursor="Hand" />
            </StackPanel>
        </Border>

        <TabControl Margin="6" SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}" SelectionChanged="MainTabs_SelectionChanged">
            <!-- ===================== START ===================== -->
            <TabItem Header="{DynamicResource t_start}">
                <ScrollViewer>
                    <WrapPanel Margin="12">
                        <Border Classes="card" Width="280" Height="110">
                            <StackPanel Spacing="4">
                                <TextBlock Text="{DynamicResource c_client}" Classes="cardheader" />
                                <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource c_gui}" Classes="lbl" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding GuiVersion}" Classes="val" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource c_core}" Classes="lbl" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CoreVersion}" Classes="val" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Classes="card" Width="300" Height="230">
                            <StackPanel Spacing="4">
                                <TextBlock Text="{DynamicResource c_network}" Classes="cardheader" />
                                <Grid ColumnDefinitions="150,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource c_users}" Classes="lbl" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Users}" Classes="val" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource c_files}" Classes="lbl" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Files}" Classes="val" />
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource c_totalsize}" Classes="lbl" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding FileSize, Converter={StaticResource NetworkSizeConverter}}" Classes="val" />
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="{DynamicResource c_connections}" Classes="lbl" />
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding OpenConnections}" Classes="val" />
                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="{DynamicResource c_uploadqueue}" Classes="lbl" />
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding UploadQueue}" Classes="val" />
                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="{DynamicResource c_firewall}" Classes="lbl" />
                                    <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal" Spacing="6">
                                        <Image Width="14" Height="14" Source="{Binding Firewalled, Converter={StaticResource FirewallConverter}}" />
                                        <TextBlock Classes="val" Text="{Binding Firewalled, Converter={StaticResource BoolToFirewallTextConverter}}" />
                                    </StackPanel>
                                    <TextBlock Grid.Row="6" Grid.Column="0" Text="{DynamicResource c_ip}" Classes="lbl" />
                                    <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding OwnIp}" Classes="val" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Classes="card" Width="420" Height="230">
                            <StackPanel Spacing="4">
                                <TextBlock Text="{DynamicResource c_server}" Classes="cardheader" />
                                <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource c_servername}" Classes="lbl" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ServerName}" Classes="val" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource c_connectedsince}" Classes="lbl" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ConnectedSince}" Classes="val" />
                                </Grid>
                                <TextBlock Text="{DynamicResource c_message}" Classes="lbl" Margin="0,6,0,0" />
                                <ScrollViewer Height="120">
                                    <TextBlock Text="{Binding WelcomeMessage}" Classes="val" TextWrapping="Wrap" />
                                </ScrollViewer>
                            </StackPanel>
                        </Border>
                    </WrapPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ===================== DOWNLOADS ===================== -->
            <TabItem Header="{DynamicResource t_downloads}">
                <DockPanel Margin="4">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="6" Margin="4">
                        <Button Content="{DynamicResource d_continue}" Command="{Binding ContinueCommand}" />
                        <Button Content="{DynamicResource d_break}" Command="{Binding BreakCommand}" />
                        <Button Content="{DynamicResource d_cancel}" Command="{Binding CancelCommand}" />
                        <Button Content="{DynamicResource d_clean}" Command="{Binding CleanFinishedCommand}" />
                        <Border Width="1" Background="{DynamicResource TextSecondaryBrush}" Margin="4,0" />
                        <TextBlock Text="{DynamicResource d_power}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" />
                        <ComboBox x:CompileBindings="False" Width="70" ItemsSource="{Binding PowerValues}" SelectedItem="{Binding SelectedPowerValue}" />
                        <Button Content="{DynamicResource d_apply}" Command="{Binding ApplyPowerDownloadCommand}" />
                        <TextBlock Text="{DynamicResource d_priority}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" />
                        <ComboBox x:CompileBindings="False" Width="70" ItemsSource="{Binding PriorityValues}" SelectedItem="{Binding SelectedPriority}" />
                        <Button Content="{DynamicResource d_setprio}" Command="{Binding SetDownloadPriorityCommand}" />
                    </StackPanel>

                    <Grid x:Name="DownloadsSplitGrid" RowDefinitions="*,4,250">
                        <DataGrid Grid.Row="0" x:Name="DownloadsGrid" x:CompileBindings="False" ItemsSource="{Binding DownloadsView}"
                                  SelectedItem="{Binding SelectedDownload}" IsReadOnly="True" CanUserSortColumns="True" SelectionMode="Extended"
                                  SelectionChanged="DownloadsGrid_SelectionChanged"
                                  GridLinesVisibility="Horizontal" CanUserResizeColumns="True" CanUserReorderColumns="True">
                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="{DynamicResource d_continue}" Command="{Binding ContinueCommand}" InputGesture="F2" />
                                    <MenuItem Header="{DynamicResource d_break}" Command="{Binding BreakCommand}" InputGesture="F3" />
                                    <MenuItem Header="{DynamicResource d_cancel}" Command="{Binding CancelCommand}" InputGesture="F4" />
                                    <MenuItem Header="{DynamicResource d_renamebtn}" Command="{Binding RenameCommand}" InputGesture="F6" />
                                    <MenuItem Header="{DynamicResource d_targetdir}" Command="{Binding SetTargetDirCommand}" InputGesture="F7" />
                                    <MenuItem Header="{DynamicResource d_clean}" Command="{Binding CleanFinishedCommand}" InputGesture="F5" />
                                    <Separator />
                                    <MenuItem Header="{DynamicResource d_copylink}" Command="{Binding CopyDownloadLinkCommand}" InputGesture="F8" />
                                    <MenuItem Header="{DynamicResource d_copysource}" Command="{Binding CopyDownloadSourceCommand}" InputGesture="F9" />
                                    <MenuItem Header="{DynamicResource d_releaseinfo}" Command="{Binding ReleaseInfoDownloadCommand}" />
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                            <DataGrid.Styles>
                                <Style Selector="DataGridRow">
                                    <Setter Property="Background" Value="{Binding Status, Converter={StaticResource DownloadRowBrushConverter}}" />
                                </Style>
                            </DataGrid.Styles>
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="{DynamicResource col_file}" Width="*" SortMemberPath="FileName">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                                                <Image Width="16" Height="16" Source="{Binding FileName, Converter={StaticResource FileIconConverter}}" />
                                                <TextBlock Text="{Binding FileName}" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="{DynamicResource col_status}" Binding="{Binding Status, Converter={StaticResource DownloadStatusConverter}, Mode=OneWay}" Width="110" />
                                <DataGridTextColumn Header="{DynamicResource col_size}" Binding="{Binding Size, Converter={StaticResource FileSizeConverter}, Mode=OneWay}" Width="90" />
                                <DataGridTextColumn Header="{DynamicResource col_loaded}" Binding="{Binding DownloadedFilesize, Converter={StaticResource FileSizeConverter}, Mode=OneWay}" Width="90" />
                                <DataGridTextColumn Header="{DynamicResource col_speed}" Binding="{Binding Speed, Converter={StaticResource FileSizeConverter}, Mode=OneWay}" Width="90" />
                                <DataGridTextColumn Header="{DynamicResource col_time}" Binding="{Binding TimeToEnd, Converter={StaticResource TimeConverter}, Mode=OneWay}" Width="90" />
                                <DataGridTemplateColumn Header="{DynamicResource col_percent}" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Panel Margin="2,3" ClipToBounds="True">
                                                <ProgressBar Minimum="0" Maximum="100" Height="14" MinWidth="0"
                                                             Value="{Binding Percentages, Converter={StaticResource PercentTextConverter}}" />
                                                <TextBlock Text="{Binding Percentages}" FontSize="10"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                                            </Panel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="{DynamicResource col_rest}" Binding="{Binding DownloadRest, Converter={StaticResource FileSizeConverter}, Mode=OneWay}" Width="90" />
                                <DataGridTextColumn Header="{DynamicResource col_power}" Binding="{Binding PowerDownload, Converter={StaticResource PowerDownloadConverter}, Mode=OneWay}" Width="70" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <GridSplitter Grid.Row="1" ResizeDirection="Rows" HorizontalAlignment="Stretch" Background="{DynamicResource SurfaceBrush}" />

                        <TabControl Grid.Row="2" Margin="0,4,0,0">
                          <TabItem Header="{DynamicResource tab_sources}">
                            <DataGrid x:Name="SourcesGrid" x:CompileBindings="False" ItemsSource="{Binding DownloadSources}" IsReadOnly="True"
                                      GridLinesVisibility="Horizontal" CanUserResizeColumns="True" CanUserReorderColumns="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="{DynamicResource col_nick}" Binding="{Binding NickName, Mode=OneWay}" Width="*" />
                                    <DataGridTextColumn Header="{DynamicResource col_status}" Binding="{Binding Status, Converter={StaticResource UserStatusConverter}, Mode=OneWay}" Width="110" />
                                    <DataGridTextColumn Header="{DynamicResource col_size}" Binding="{Binding FileSize, Converter={StaticResource FileSizeConverter}, Mode=OneWay}" Width="90" />
                                    <DataGridTextColumn Header="{DynamicResource col_loaded}" Binding="{Binding ActualFileSize, Converter={StaticResource FileSizeConverter}, Mode=OneWay}" Width="90" />
                                    <DataGridTextColumn Header="{DynamicResource col_speed}" Binding="{Binding Speed, Converter={StaticResource FileSizeConverter}, Mode=OneWay}" Width="90" />
                                    <DataGridTextColumn Header="{DynamicResource col_time}" Binding="{Binding TimeToEnd, Converter={StaticResource TimeConverter}, Mode=OneWay}" Width="90" />
                                    <DataGridTextColumn Header="{DynamicResource col_percent}" Binding="{Binding Percentages, Mode=OneWay}" Width="70" />
                                    <DataGridTextColumn Header="{DynamicResource col_rest}" Binding="{Binding FileSizeToGet, Converter={StaticResource FileSizeConverter}, Mode=OneWay}" Width="90" />
                                    <DataGridTextColumn Header="{DynamicResource col_power}" Binding="{Binding PowerDownload, Converter={StaticResource PowerDownloadConverter}, Mode=OneWay}" Width="70" />
                                    <DataGridTextColumn Header="{DynamicResource col_version}" Binding="{Binding Version, Mode=OneWay}" Width="110" />
                                </DataGrid.Columns>
                            </DataGrid>
                          </TabItem>
                          <TabItem Header="{DynamicResource pl_title}">
                            <!-- Partlisten-Verfuegbarkeitsbalken des gewaehlten Downloads -->
                            <DockPanel Margin="2,4,2,2">
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="12" Margin="0,0,0,3">
                                <TextBlock Text="{DynamicResource pl_title}" Classes="lbl" VerticalAlignment="Center" />
                                <StackPanel Orientation="Horizontal" Spacing="3" VerticalAlignment="Center">
                                    <Rectangle Width="10" Height="10" Fill="Red" /><TextBlock Text="{DynamicResource pl_unavail}" Classes="lbl" />
                                    <Rectangle Width="10" Height="10" Fill="#4C6BFF" Margin="8,0,0,0" /><TextBlock Text="{DynamicResource pl_avail}" Classes="lbl" />
                                    <Rectangle Width="10" Height="10" Fill="Orange" Margin="8,0,0,0" /><TextBlock Text="{DynamicResource pl_loaded}" Classes="lbl" />
                                    <Rectangle Width="10" Height="10" Fill="Yellow" Margin="8,0,0,0" /><TextBlock Text="{DynamicResource pl_active}" Classes="lbl" />
                                    <Rectangle Width="10" Height="10" Fill="Green" Margin="8,0,0,0" /><TextBlock Text="{DynamicResource pl_finished}" Classes="lbl" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Margin="18,0,0,0">
                                    <TextBlock Text="{DynamicResource pl_size}" Classes="lbl" VerticalAlignment="Center" />
                                    <ComboBox x:CompileBindings="False" Width="70" ItemsSource="{Binding PartlistSizes}" SelectedItem="{Binding PartlistSize}" />
                                </StackPanel>
                            </StackPanel>
                            <Border BorderBrush="{DynamicResource TextSecondaryBrush}" BorderThickness="1">
                                <Image Source="{Binding PartlistImage}" Stretch="Fill"
                                       PointerMoved="Partlist_PointerMoved" PointerExited="Partlist_PointerExited" />
                            </Border>
                            </DockPanel>
                          </TabItem>
                        </TabControl>
                    </Grid>
                </DockPanel>
            </TabItem>

            <!-- ===================== UPLOADS ===================== -->
            <TabItem Header="{DynamicResource t_uploads}">
                <!-- Zwei sternhohe Bereiche mit Splitter dazwischen; der Splitter darf NICHT direkt an
                     einer Auto-Zeile (Label) liegen, sonst laesst er sich nur in eine Richtung ziehen. -->
                <Grid x:Name="UploadsSplitGrid" RowDefinitions="*,4,*" Margin="4">
                  <Grid Grid.Row="0" RowDefinitions="Auto,*">
                    <TextBlock Grid.Row="0" Text="{DynamicResource u_active}" Classes="lbl" Margin="2" />
                    <DataGrid Grid.Row="1" x:Name="UploadsGrid" x:CompileBindings="False" ItemsSource="{Binding ActiveUploads}" IsReadOnly="True"
                              GridLinesVisibility="Horizontal" CanUserResizeColumns="True" CanUserReorderColumns="True">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="{DynamicResource col_file}" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                                            <Image Width="16" Height="16" Source="{Binding FileName, Converter={StaticResource FileIconConverter}}" />
                                            <TextBlock Text="{Binding FileName}" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="{DynamicResource col_nick}" Binding="{Binding Nick, Mode=OneWay}" Width="140" />
                            <DataGridTextColumn Header="{DynamicResource col_speed}" Binding="{Binding Speed, Converter={StaticResource FileSizeConverter}, Mode=OneWay}" Width="90" />
                            <DataGridTemplateColumn Header="{DynamicResource col_percent}" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Panel Margin="2,3" ClipToBounds="True">
                                            <ProgressBar Minimum="0" Maximum="100" Height="14" MinWidth="0"
                                                         Value="{Binding Percentages, Converter={StaticResource PercentTextConverter}}" />
                                            <TextBlock Text="{Binding Percentages}" FontSize="10"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                                        </Panel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <!-- Wasserstand: Fuellstand der Datei bei der Gegenstelle (Loaded 0..1). -->
                            <DataGridTemplateColumn Header="{DynamicResource col_waterlevel}" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Panel Margin="2,3" ClipToBounds="True">
                                            <ProgressBar Minimum="0" Maximum="1" Height="14" MinWidth="0"
                                                         Value="{Binding Loaded}" />
                                            <TextBlock Text="{Binding WPercentages}" FontSize="10"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                                        </Panel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="{DynamicResource col_prio}" Binding="{Binding Priority, Mode=OneWay}" Width="80" />
                            <DataGridTextColumn Header="{DynamicResource col_version}" Binding="{Binding Version, Mode=OneWay}" Width="140" />
                        </DataGrid.Columns>
                    </DataGrid>
                  </Grid>

                  <GridSplitter Grid.Row="1" ResizeDirection="Rows" HorizontalAlignment="Stretch" Background="{DynamicResource SurfaceBrush}" />

                  <Grid Grid.Row="2" RowDefinitions="Auto,*">
                    <TextBlock Grid.Row="0" Text="{DynamicResource u_queue}" Classes="lbl" Margin="2" />
                    <DataGrid Grid.Row="1" x:CompileBindings="False" ItemsSource="{Binding QueuedUploads}" IsReadOnly="True"
                              GridLinesVisibility="Horizontal" CanUserResizeColumns="True" CanUserReorderColumns="True">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="{DynamicResource col_file}" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                                            <Image Width="16" Height="16" Source="{Binding FileName, Converter={StaticResource FileIconConverter}}" />
                                            <TextBlock Text="{Binding FileName}" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="{DynamicResource col_nick}" Binding="{Binding Nick, Mode=OneWay}" Width="140" />
                            <DataGridTextColumn Header="{DynamicResource col_prio}" Binding="{Binding Priority, Mode=OneWay}" Width="80" />
                            <DataGridTextColumn Header="{DynamicResource col_lastseen}" Binding="{Binding LastConnection, Converter={StaticResource SecondsToDateConverter}, Mode=OneWay}" Width="150" />
                            <DataGridTextColumn Header="{DynamicResource col_version}" Binding="{Binding Version, Mode=OneWay}" Width="140" />
                        </DataGrid.Columns>
                    </DataGrid>
                  </Grid>
                </Grid>
            </TabItem>

            <!-- ===================== SUCHEN ===================== -->
            <TabItem Header="{DynamicResource t_search}">
                <DockPanel Margin="4">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="6" Margin="4">
                        <TextBox Width="300" Watermark="{DynamicResource s_placeholder}" Text="{Binding SearchText, Mode=TwoWay}" />
                        <Button Content="{DynamicResource s_search}" Command="{Binding StartSearchCommand}" />
                        <Button Content="{DynamicResource s_stop}" Command="{Binding StopSearchCommand}" />
                        <Button Content="{DynamicResource s_close}" Command="{Binding CloseSearchTabCommand}" />
                        <Button Content="{DynamicResource s_download}" Command="{Binding DownloadSearchResultCommand}" />
                        <Button Content="{DynamicResource d_releaseinfo}" Command="{Binding ReleaseInfoSearchCommand}" />
                        <Button Content="{DynamicResource d_copylink}" Command="{Binding CopySearchLinkCommand}" />
                    </StackPanel>

                    <!-- Ein Ergebnis-Tab pro Suche (analog WPF CloseableTabItem) -->
                    <TabControl x:CompileBindings="False" ItemsSource="{Binding SearchTabs}" SelectedItem="{Binding SelectedSearchTab}">
                        <TabControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Title}" />
                            </DataTemplate>
                        </TabControl.ItemTemplate>
                        <TabControl.ContentTemplate>
                            <DataTemplate>
                                <DockPanel>
                                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="2">
                                        <TextBlock Text="{DynamicResource s_hits}" Foreground="{DynamicResource TextSecondaryBrush}" />
                                        <TextBlock Text="{Binding FoundFiles}" Foreground="{DynamicResource TextPrimaryBrush}" />
                                        <TextBlock Text="{DynamicResource s_sources}" Foreground="{DynamicResource TextSecondaryBrush}" />
                                        <TextBlock Text="{Binding SumSearches}" Foreground="{DynamicResource TextPrimaryBrush}" />
                                    </StackPanel>
                                    <DataGrid ItemsSource="{Binding Results}" SelectedItem="{Binding SelectedResult}" IsReadOnly="True"
                                              GridLinesVisibility="Horizontal" CanUserResizeColumns="True" CanUserReorderColumns="True">
                                        <DataGrid.Columns>
                                            <DataGridTemplateColumn Header="{DynamicResource col_file}" Width="*">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                                                            <Image Width="16" Height="16" Source="{Binding FileName.Name, Converter={StaticResource FileIconConverter}}" />
                                                            <TextBlock Text="{Binding FileName.Name}" VerticalAlignment="Center" />
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTextColumn Header="{DynamicResource col_size}" Binding="{Binding Size, Converter={StaticResource FileSizeConverter}, Mode=OneWay}" Width="100" />
                                            <DataGridTextColumn Header="{DynamicResource col_checksum}" Binding="{Binding Checksum, Mode=OneWay}" Width="260" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </DockPanel>
                            </DataTemplate>
                        </TabControl.ContentTemplate>
                    </TabControl>
                </DockPanel>
            </TabItem>

            <!-- ===================== SERVER ===================== -->
            <TabItem Header="{DynamicResource t_server}">
                <DockPanel Margin="4">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="6" Margin="4">
                        <Button Content="{DynamicResource sv_connect}" Command="{Binding ConnectServerCommand}" />
                        <Button Content="{DynamicResource sv_remove}" Command="{Binding RemoveServerCommand}" />
                        <Button Content="{DynamicResource sv_getlist}" Command="{Binding AddOfficialServersCommand}" />
                        <Button Content="{DynamicResource sv_serverlink}" Command="{Binding CopyServerLinkCommand}" />
                    </StackPanel>
                    <DataGrid x:Name="ServersGrid" x:CompileBindings="False" ItemsSource="{Binding ServersView}"
                              SelectedItem="{Binding SelectedServer}" IsReadOnly="True" CanUserSortColumns="True"
                              GridLinesVisibility="Horizontal" CanUserResizeColumns="True" CanUserReorderColumns="True">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="{DynamicResource sv_connect}" Command="{Binding ConnectServerCommand}" />
                                <MenuItem Header="{DynamicResource sv_getlist}" Command="{Binding AddOfficialServersCommand}" />
                                <MenuItem Header="{DynamicResource sv_remove}" Command="{Binding RemoveServerCommand}" />
                                <MenuItem Header="{DynamicResource sv_serverlink}" Command="{Binding CopyServerLinkCommand}" />
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Styles>
                            <Style Selector="DataGridRow">
                                <Setter Property="Background" Value="{Binding IsConnected, Converter={StaticResource ServerRowBrushConverter}}" />
                            </Style>
                        </DataGrid.Styles>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{DynamicResource col_name}" Binding="{Binding Name, Mode=OneWay}" Width="*" />
                            <DataGridTextColumn Header="{DynamicResource col_host}" Binding="{Binding Host, Mode=OneWay}" Width="220" />
                            <DataGridTextColumn Header="{DynamicResource col_port}" Binding="{Binding Port, Mode=OneWay}" Width="80" />
                            <DataGridTextColumn Header="{DynamicResource col_lastseen}" Binding="{Binding LastSeen, Converter={StaticResource SecondsToDateConverter}, Mode=OneWay}" Width="150" />
                            <DataGridTextColumn Header="{DynamicResource col_tries}" Binding="{Binding ConnectionTry, Mode=OneWay}" Width="90" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <!-- ===================== MEIN SHARE ===================== -->
            <TabItem Header="{DynamicResource t_share}">
                <Grid x:Name="SharesSplitGrid" ColumnDefinitions="320,4,*" Margin="4">
                    <!-- Links: Freigabe-Verzeichnisbaum -->
                    <DockPanel Grid.Column="0">
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="6" Margin="2">
                            <Button Content="{DynamicResource sh_loadtree}" Command="{Binding LoadShareTreeCommand}" />
                            <Button Content="{DynamicResource sh_unshare}" Command="{Binding UnshareFolderCommand}" />
                        </StackPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="6" Margin="2,0,2,2">
                            <Button Content="{DynamicResource sh_share}" Command="{Binding ShareFolderNoSubCommand}" />
                            <Button Content="{DynamicResource sh_sharesub}" Command="{Binding ShareFolderCommand}" />
                        </StackPanel>
                        <TextBlock DockPanel.Dock="Top" Text="{DynamicResource sh_dirs}" Classes="lbl" Margin="2,0,0,2" />
                        <TextBlock DockPanel.Dock="Bottom" Text="{DynamicResource sh_sharedhint}" Classes="lbl" Margin="2,4,2,0" FontSize="11" TextWrapping="Wrap" />
                        <!-- Freigegebene Ordner sind im Baum gruen/fett markiert (eigene Liste entfaellt). -->
                        <TreeView x:CompileBindings="False" ItemsSource="{Binding ShareTree}" SelectedItem="{Binding SelectedShareNode}">
                            <TreeView.Styles>
                                <Style Selector="TreeViewItem">
                                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                </Style>
                            </TreeView.Styles>
                            <TreeView.ItemTemplate>
                                <TreeDataTemplate ItemsSource="{Binding Children}">
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <Panel Width="15" Height="15" VerticalAlignment="Center">
                                            <Image Source="{StaticResource FolderIcon}" IsVisible="{Binding ShowPlainIcon}" />
                                            <Image Source="{StaticResource FolderIconShared}" IsVisible="{Binding ShowSharedIcon}" />
                                            <Image Source="{StaticResource FolderIconAncestor}" IsVisible="{Binding ShowAncestorIcon}" />
                                            <Image Source="{StaticResource FolderIconTemp}" IsVisible="{Binding ShowTempIcon}" />
                                        </Panel>
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"
                                                   FontWeight="{Binding IsSharedContent, Converter={StaticResource BoolToFontWeightConverter}}" />
                                    </StackPanel>
                                </TreeDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </DockPanel>

                    <GridSplitter Grid.Column="1" ResizeDirection="Columns" Background="{DynamicResource SurfaceBrush}" />

                    <!-- Rechts: freigegebene Dateien -->
                    <DockPanel Grid.Column="2">
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="6" Margin="4">
                            <Button Content="{DynamicResource sh_refresh}" Command="{Binding RefreshShareCommand}" />
                            <Button Content="{DynamicResource sh_check}" Command="{Binding CheckShareCommand}" />
                            <Border Width="1" Background="{DynamicResource TextSecondaryBrush}" Margin="2,0" />
                            <TextBlock Text="{DynamicResource d_priority}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" />
                            <ComboBox x:CompileBindings="False" Width="70" ItemsSource="{Binding PriorityValues}" SelectedItem="{Binding SelectedPriority}" />
                            <Button Content="{DynamicResource sh_setprio}" Command="{Binding SetSharePriorityCommand}" />
                            <Button Content="{DynamicResource sh_delprio}" Command="{Binding DelSharePriorityCommand}" />
                        </StackPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="6" Margin="4,0,4,4">
                            <TextBlock Text="{DynamicResource sh_filter}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" />
                            <TextBox Width="240" Text="{Binding ShareFilterText, Mode=TwoWay}" />
                            <Button Content="{DynamicResource sh_showall}" Command="{Binding ShowAllSharesCommand}" />
                        </StackPanel>
                        <DataGrid x:CompileBindings="False" x:Name="SharesGrid" ItemsSource="{Binding SharesView}"
                                  SelectedItem="{Binding SelectedShare}" IsReadOnly="True" SelectionMode="Extended" CanUserSortColumns="True"
                                  GridLinesVisibility="Horizontal" CanUserResizeColumns="True" CanUserReorderColumns="True">
                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="{DynamicResource sh_setprio}" Command="{Binding SetSharePriorityCommand}" />
                                    <MenuItem Header="{DynamicResource sh_delprio}" Command="{Binding DelSharePriorityCommand}" />
                                    <Separator />
                                    <MenuItem Header="{DynamicResource d_copylink}" Command="{Binding CopyShareLinkCommand}" />
                                    <MenuItem Header="{DynamicResource d_copylinks}" Click="CopyShareLinks_Click" />
                                    <MenuItem Header="{DynamicResource d_copysource}" Command="{Binding CopyShareSourceCommand}" />
                                    <MenuItem Header="{DynamicResource d_copysources}" Click="CopyShareSources_Click" />
                                    <MenuItem Header="{DynamicResource d_releaseinfo}" Command="{Binding ReleaseInfoShareCommand}" />
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="{DynamicResource col_file}" Width="*" SortMemberPath="ShortFileName">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                                                <Image Width="16" Height="16" Source="{Binding ShortFileName, Converter={StaticResource FileIconConverter}}" />
                                                <TextBlock Text="{Binding ShortFileName}" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="{DynamicResource col_size}" Binding="{Binding Size, Converter={StaticResource FileSizeConverter}, Mode=OneWay}" Width="100" />
                                <DataGridTextColumn Header="{DynamicResource col_prio}" Binding="{Binding Priority, Mode=OneWay}" Width="80" />
                                <DataGridTextColumn Header="{DynamicResource col_lastasked}" Binding="{Binding LastAsked, Converter={StaticResource SecondsToDateConverter}, Mode=OneWay}" Width="150" />
                                <DataGridTextColumn Header="{DynamicResource col_asks}" Binding="{Binding AskCount, Mode=OneWay}" Width="90" />
                                <DataGridTextColumn Header="{DynamicResource col_hits}" Binding="{Binding SearchCount, Mode=OneWay}" Width="100" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Grid>
            </TabItem>

            <!-- ===================== EINSTELLUNGEN ===================== -->
            <TabItem Header="{DynamicResource t_settings}">
                <ScrollViewer>
                <StackPanel Margin="16" Spacing="14" MaxWidth="700" HorizontalAlignment="Left">
                  <Border Classes="card" Margin="0">
                   <StackPanel Spacing="10">
                    <TextBlock Text="{DynamicResource c_gui}" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                    <Grid ColumnDefinitions="220,*" RowDefinitions="Auto,Auto,Auto">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource set_refresh}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" />
                        <TextBox Grid.Row="0" Grid.Column="1" Width="120" HorizontalAlignment="Left" Text="{Binding RefreshRate, Mode=TwoWay}" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource set_infourl}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,8,0,0" />
                        <TextBox Grid.Row="1" Grid.Column="1" Margin="0,8,0,0" Text="{Binding ReleaseInfoHost, Mode=TwoWay}" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource set_design}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,8,0,0" />
                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Spacing="6" Margin="0,8,0,0">
                            <Button Content="Dunkel" Command="{Binding ApplyDarkThemeCommand}" />
                            <Button Content="Hell" Command="{Binding ApplyLightThemeCommand}" />
                        </StackPanel>
                    </Grid>
                    <CheckBox Content="{DynamicResource set_showlogin}" IsChecked="{Binding ShowLoginNextStart, Mode=TwoWay}"
                              Foreground="{DynamicResource TextPrimaryBrush}" />
                    <CheckBox Content="{DynamicResource set_protocol}" IsChecked="{Binding RegisterAjfspProtocol, Mode=TwoWay}"
                              IsVisible="{Binding IsProtocolSupported}" Foreground="{DynamicResource TextPrimaryBrush}" />
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Content="{DynamicResource set_guisave}" Command="{Binding SaveSettingsCommand}" Background="{DynamicResource AccentBrush}" Foreground="White" />
                        <TextBlock Text="{Binding SettingsStatus}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" />
                    </StackPanel>
                   </StackPanel>
                  </Border>

                  <Border Classes="card" Margin="0">
                   <StackPanel Spacing="10">
                    <TextBlock Text="{DynamicResource set_core}" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                    <Grid ColumnDefinitions="220,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource set_nick}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" />
                        <TextBox  Grid.Row="0" Grid.Column="1" Text="{Binding CoreNick, Mode=TwoWay}" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource set_tempdir}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,6,0,0" />
                        <TextBox  Grid.Row="1" Grid.Column="1" Margin="0,6,0,0" Text="{Binding CoreTempDir, Mode=TwoWay}" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource set_incdir}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,6,0,0" />
                        <TextBox  Grid.Row="2" Grid.Column="1" Margin="0,6,0,0" Text="{Binding CoreIncomingDir, Mode=TwoWay}" />
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="{DynamicResource set_coreport}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,6,0,0" />
                        <TextBox  Grid.Row="3" Grid.Column="1" Width="120" HorizontalAlignment="Left" Margin="0,6,0,0" Text="{Binding CorePort, Mode=TwoWay}" />
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="{DynamicResource set_xmlport}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,6,0,0" />
                        <TextBox  Grid.Row="4" Grid.Column="1" Width="120" HorizontalAlignment="Left" Margin="0,6,0,0" Text="{Binding CoreXmlPort, Mode=TwoWay}" />
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="{DynamicResource set_maxconn}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,6,0,0" />
                        <TextBox  Grid.Row="5" Grid.Column="1" Width="120" HorizontalAlignment="Left" Margin="0,6,0,0" Text="{Binding CoreMaxConnections, Mode=TwoWay}" />
                        <TextBlock Grid.Row="6" Grid.Column="0" Text="{DynamicResource set_maxup}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,6,0,0" />
                        <TextBox  Grid.Row="6" Grid.Column="1" Width="160" HorizontalAlignment="Left" Margin="0,6,0,0" Text="{Binding CoreMaxUploadKb, Mode=TwoWay}" />
                        <TextBlock Grid.Row="7" Grid.Column="0" Text="{DynamicResource set_maxdown}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,6,0,0" />
                        <TextBox  Grid.Row="7" Grid.Column="1" Width="160" HorizontalAlignment="Left" Margin="0,6,0,0" Text="{Binding CoreMaxDownloadKb, Mode=TwoWay}" />
                        <TextBlock Grid.Row="8" Grid.Column="0" Text="{DynamicResource set_speedslot}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,6,0,0" />
                        <StackPanel Grid.Row="8" Grid.Column="1" Orientation="Horizontal" Spacing="10" Margin="0,6,0,0">
                            <Slider Width="220" Minimum="{Binding SpeedSlotMin}" Maximum="{Binding SpeedSlotMax}" Value="{Binding CoreSpeedPerSlot, Mode=TwoWay}" VerticalAlignment="Center" />
                            <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}"><Run Text="{Binding CoreSpeedPerSlot}" /><Run Text=" kByte/s" /></TextBlock>
                        </StackPanel>
                        <TextBlock Grid.Row="9" Grid.Column="0" Text="{DynamicResource set_newconn}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,6,0,0" />
                        <TextBox  Grid.Row="9" Grid.Column="1" Width="120" HorizontalAlignment="Left" Margin="0,6,0,0" Text="{Binding CoreMaxNewConnectionsPerTurn, Mode=TwoWay}" />
                        <TextBlock Grid.Row="10" Grid.Column="0" Text="{DynamicResource set_sources}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,6,0,0" />
                        <TextBox  Grid.Row="10" Grid.Column="1" Width="120" HorizontalAlignment="Left" Margin="0,6,0,0" Text="{Binding CoreMaxSourcesPerFile, Mode=TwoWay}" />
                    </Grid>
                    <CheckBox Content="{DynamicResource set_autoconnect}" IsChecked="{Binding CoreAutoConnect, Mode=TwoWay}" Foreground="{DynamicResource TextPrimaryBrush}" />
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Content="{DynamicResource set_coreload}" Command="{Binding LoadCoreSettingsCommand}" />
                        <Button Content="{DynamicResource set_coresave}" Command="{Binding SaveCoreSettingsCommand}" Background="{DynamicResource AccentBrush}" Foreground="White" />
                        <TextBlock Text="{Binding CoreSettingsStatus}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" />
                    </StackPanel>
                   </StackPanel>
                  </Border>

                  <Border Classes="card" Margin="0">
                   <StackPanel Spacing="10">
                    <TextBlock Text="{DynamicResource set_pwchange}" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBox Width="220" PasswordChar="•" Watermark="{DynamicResource set_newpw}" Text="{Binding NewPassword, Mode=TwoWay}" />
                        <Button Content="{DynamicResource set_pwset}" Command="{Binding ChangePasswordCommand}" />
                    </StackPanel>
                   </StackPanel>
                  </Border>
                </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
