<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Apfelmus.Avalonia.Views.RenameDialog"
        Title="Umbenennen" Width="460" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" CanResize="False"
        Background="{DynamicResource WindowBackgroundBrush}">
    <StackPanel Margin="16" Spacing="10">
        <TextBlock Text="{DynamicResource d_rename}" Foreground="{DynamicResource TextSecondaryBrush}" />
        <TextBox x:Name="NameBox" />
        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
            <Button Content="OK" Click="Ok_Click" Background="{DynamicResource AccentBrush}" Foreground="White" />
            <Button Content="Abbrechen" Click="Cancel_Click" />
        </StackPanel>
    </StackPanel>
</Window>
