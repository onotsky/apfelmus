<Application x:Class="Apfelmus.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Theme.Dark/Light.xaml wird zur Laufzeit von ThemeManager.ApplyStartupTheme() ergaenzt -->
                <ResourceDictionary Source="/Resourcen/ControlStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
