<Window x:Class="Apfelmus.MessageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="appleJuice" SizeToContent="Height" Width="440" MinHeight="120"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner" WindowStyle="None"
        ShowInTaskbar="False" Background="{DynamicResource WindowBackgroundBrush}">
    <!--
        Schlichtes, themekonformes Meldungsfenster (Ersatz fuer die ungetheimte MessageBox).
        Muster wie RenameDownloadWindow/TargetdirWindow: WindowStyle=None + Theme-Brushes.
        Der duenne Accent-Rahmen gibt dem randlosen Fenster eine sichtbare Kante.
    -->
    <Border BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Name="txtMessage" TextWrapping="Wrap"
                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,4,0,20" />
            <Button Grid.Row="1" Name="btnOk" Content="OK" Width="120" Height="30"
                    HorizontalAlignment="Center" IsDefault="True" IsCancel="True" Click="btnOk_Click" />
        </Grid>
    </Border>
</Window>
