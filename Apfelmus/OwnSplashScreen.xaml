<Window x:Class="Apfelmus.OwnSplashScreen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Apfelmus"
        Width="380" Height="260"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen"
        Visibility="Visible">

    <!--
        Bewusst ein fest verdrahtetes, markentreues Farbschema (Anthrazit/Charcoal + Gruen wie
        ZITCS), unabhaengig vom aktuell gewaehlten App-Theme (Dunkel/Hell) - ein Splashscreen ist
        ein Markenmoment, kein themebares Fenster.
    -->
    <Window.Resources>
        <Style x:Key="SplashProgressBar" TargetType="{x:Type ProgressBar}">
            <Setter Property="Height" Value="4" />
            <Setter Property="Background" Value="#FF2A313B" />
            <Setter Property="Foreground" Value="#FF2ECC71" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ProgressBar}">
                        <Grid>
                            <Border Background="{TemplateBinding Background}" CornerRadius="2" />
                            <Border x:Name="PART_Track" Margin="0">
                                <Decorator x:Name="PART_Indicator" HorizontalAlignment="Left">
                                    <Border Background="{TemplateBinding Foreground}" CornerRadius="2" />
                                </Decorator>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="10" Background="#FF1E2329" BorderBrush="#FF2ECC71" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="28" ShadowDepth="0" Opacity="0.5" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,8,0,14">
                <Image Name="Apple" Source="/ApfelmusFramework;component/Images/Apple-icon.png" Width="88" Height="88"
                       RenderOptions.BitmapScalingMode="HighQuality" Margin="0,0,0,16" />
                <TextBlock Text="Apfelmus" FontFamily="Segoe UI Semibold" FontSize="27" FontWeight="SemiBold"
                           Foreground="#FFECEFF1" HorizontalAlignment="Center" />
                <TextBlock Text="appleJuice Client" FontFamily="Segoe UI" FontSize="12" Foreground="#FF2ECC71"
                           HorizontalAlignment="Center" Margin="0,3,0,0" />
            </StackPanel>

            <StackPanel Grid.Row="1" Margin="32,0,32,22">
                <ProgressBar Name="pBarSplash" Style="{StaticResource SplashProgressBar}" IsIndeterminate="false" />
                <TextBlock Text="wird geladen …" FontFamily="Segoe UI" FontSize="10.5" Foreground="#FF8FA0AB"
                           HorizontalAlignment="Center" Margin="0,8,0,0" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
