<Window x:Class="Apfelmus.BaseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:ApfelmusFramework.Classes.Converter"
        Title="Apfelmus - Login" WindowStyle="None" ResizeMode="CanMinimize" WindowStartupLocation="CenterScreen" SizeToContent="Height" Width="300" Icon="/Images/Apple-icon.png" Background="{DynamicResource WindowBackgroundBrush}">
    <!--
        Layout bewusst als Grid (nicht zwei parallele StackPanels): so sitzen Label und Eingabefeld
        je Zeile garantiert auf gleicher Hoehe. Mit den Theme-Styles (Padding an TextBox/PasswordBox)
        liefen die frueheren, hoehenfixen StackPanels auseinander und verdeckten das Passwortfeld.
        SizeToContent="Height" laesst das Fenster immer genau auf den Inhalt wachsen.
    -->
    <Grid Margin="16,14">
        <Grid.Resources>
            <conv:HostnameConverter x:Key="HostnameConverter" />
        </Grid.Resources>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Label Grid.Row="0" Grid.Column="0" Name="lblHost" Content="{DynamicResource host}" VerticalAlignment="Center" Margin="0,0,8,0" />
        <TextBox Grid.Row="0" Grid.Column="1" Name="tbxHost" Margin="0,4" Text="{Binding Path=HostName, Converter={StaticResource HostnameConverter}}" />

        <Label Grid.Row="1" Grid.Column="0" Name="lblPort" Content="{DynamicResource port}" VerticalAlignment="Center" Margin="0,0,8,0" />
        <TextBox Grid.Row="1" Grid.Column="1" Name="tbxPort" Margin="0,4" Text="{Binding Path=Port}" />

        <Label Grid.Row="2" Grid.Column="0" Name="lblPasswd" Content="{DynamicResource password}" VerticalAlignment="Center" Margin="0,0,8,0" />
        <PasswordBox Grid.Row="2" Grid.Column="1" Name="pbxPasswd" Margin="0,4" PasswordChanged="pbxPasswd_PasswordChanged" />

        <CheckBox Grid.Row="3" Grid.Column="1" Name="chbxSetPass" Content="{DynamicResource savepassword}" Margin="0,8,0,0" IsChecked="{Binding Path=HideLoginWindow}" />
        <CheckBox Grid.Row="4" Grid.Column="1" Name="chbxUseCompress" Content="{DynamicResource compress}" Margin="0,6,0,0" IsChecked="{Binding Path=UseCompression}" />

        <StackPanel Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
            <Button Name="btnOk" Content="{DynamicResource ok_start}" Width="80" Click="btnOk_Click" />
            <Button Name="btnCancel" Content="{DynamicResource cancel_start}" Width="80" Margin="15,0,0,0" Click="btnCancel_Click" />
        </StackPanel>
    </Grid>
</Window>
