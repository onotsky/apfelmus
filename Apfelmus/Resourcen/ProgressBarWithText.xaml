<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:conv="clr-namespace:ApfelmusFramework.Classes.Converter">
    <conv:RectConverter x:Key="RectConverter" />

    <!--
        Flacher, moderner Fortschrittsbalken mit zentriertem Prozenttext. Der Text wird doppelt
        gezeichnet (einmal in der Track-, einmal in der Indikatorfarbe) und die zweite Kopie auf
        die Breite des Indicators geclippt - so bleibt die Zahl lesbar, egal ob sie ueber dem
        gefuellten oder dem leeren Teil des Balkens liegt.
    -->
    <Style x:Key="ProgressBarWithText" TargetType="{x:Type ProgressBar}">
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
        <Setter Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ProgressBar}">
                    <Grid x:Name="TemplateRoot" SnapsToDevicePixels="true">
                        <Rectangle x:Name="rectangle" Fill="{TemplateBinding Background}" RadiusY="3" RadiusX="3" />
                        <Rectangle x:Name="PART_Track" Margin="1" />
                        <Decorator x:Name="PART_Indicator" HorizontalAlignment="Left" Margin="1">
                            <Rectangle x:Name="Indicator" Fill="{TemplateBinding Foreground}" RadiusY="2" RadiusX="2" />
                        </Decorator>
                        <Border BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3" />
                        <TextBlock Text="{TemplateBinding Tag}" Grid.ZIndex="2" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="10" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                        <TextBlock Text="{TemplateBinding Tag}" Grid.ZIndex="3" Foreground="{DynamicResource AccentContrastBrush}" FontSize="10" FontWeight="SemiBold"
                                Width="{Binding ElementName=rectangle, Path=ActualWidth}"
                                TextAlignment="Center"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Center">
                            <TextBlock.Clip>
                                <RectangleGeometry>
                                    <RectangleGeometry.Rect>
                                        <MultiBinding Converter="{StaticResource RectConverter}">
                                            <Binding ElementName="Indicator" Path="ActualWidth"/>
                                            <Binding ElementName="Indicator" Path="ActualHeight"/>
                                        </MultiBinding>
                                    </RectangleGeometry.Rect>
                                </RectangleGeometry>
                            </TextBlock.Clip>
                        </TextBlock>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Orientation" Value="Vertical">
                            <Setter Property="LayoutTransform" TargetName="TemplateRoot">
                                <Setter.Value>
                                    <RotateTransform Angle="-90"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
