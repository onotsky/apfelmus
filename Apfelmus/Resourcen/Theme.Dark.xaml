<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dunkles Farbschema: Anthrazit/Charcoal + Gruen (ZITCS-Markenfarben, fuer Dunkelgrund aufgehellt). -->

    <Color x:Key="WindowBackgroundColor">#FF1E2329</Color>
    <Color x:Key="ChromeBackgroundColor">#FF181C21</Color>
    <Color x:Key="SurfaceColor">#FF222831</Color>
    <Color x:Key="SurfaceRaisedColor">#FF2A313B</Color>
    <Color x:Key="DividerColor">#FF39424C</Color>
    <Color x:Key="TextPrimaryColor">#FFECEFF1</Color>
    <Color x:Key="TextSecondaryColor">#FF8FA0AB</Color>
    <Color x:Key="AccentColor">#FF2ECC71</Color>
    <Color x:Key="AccentHoverColor">#FF3FDB82</Color>
    <Color x:Key="AccentPressedColor">#FF24A85D</Color>
    <Color x:Key="AccentContrastColor">#FF0B1210</Color>
    <Color x:Key="SelectionBackgroundColor">#FF24392E</Color>
    <Color x:Key="SelectionForegroundColor">#FFECEFF1</Color>
    <Color x:Key="ControlBackgroundColor">#FF262D35</Color>
    <Color x:Key="ControlBorderColor">#FF414B56</Color>
    <Color x:Key="HeaderBackgroundColor">#FF2A313B</Color>
    <Color x:Key="ScrollThumbColor">#FF3A434D</Color>
    <Color x:Key="ScrollThumbHoverColor">#FF4A5560</Color>
    <Color x:Key="ValueColor">#FF3FDB82</Color>
    <Color x:Key="DisabledColor">#FF5A636C</Color>

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource WindowBackgroundColor}" />
    <SolidColorBrush x:Key="ChromeBackgroundBrush" Color="{StaticResource ChromeBackgroundColor}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="SurfaceRaisedBrush" Color="{StaticResource SurfaceRaisedColor}" />
    <SolidColorBrush x:Key="DividerBrush" Color="{StaticResource DividerColor}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}" />
    <SolidColorBrush x:Key="AccentPressedBrush" Color="{StaticResource AccentPressedColor}" />
    <SolidColorBrush x:Key="AccentContrastBrush" Color="{StaticResource AccentContrastColor}" />
    <SolidColorBrush x:Key="SelectionBackgroundBrush" Color="{StaticResource SelectionBackgroundColor}" />
    <SolidColorBrush x:Key="SelectionForegroundBrush" Color="{StaticResource SelectionForegroundColor}" />
    <SolidColorBrush x:Key="ControlBackgroundBrush" Color="{StaticResource ControlBackgroundColor}" />
    <SolidColorBrush x:Key="ControlBorderBrush" Color="{StaticResource ControlBorderColor}" />
    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="{StaticResource HeaderBackgroundColor}" />
    <SolidColorBrush x:Key="ScrollThumbBrush" Color="{StaticResource ScrollThumbColor}" />
    <SolidColorBrush x:Key="ScrollThumbHoverBrush" Color="{StaticResource ScrollThumbHoverColor}" />
    <SolidColorBrush x:Key="ValueBrush" Color="{StaticResource ValueColor}" />
    <SolidColorBrush x:Key="DisabledBrush" Color="{StaticResource DisabledColor}" />

</ResourceDictionary>
